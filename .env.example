# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database migration (Settings → Database → Connection string → URI)
# Or set SUPABASE_DB_PASSWORD with your project database password
DATABASE_URL=
SUPABASE_DB_PASSWORD=

# AI Agent
AGENT_PROVIDER=mock
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional observability (match region: EU = cloud.langfuse.com, US = us.cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
